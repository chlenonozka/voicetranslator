#!/usr/bin/env bash
set -euo pipefail

readonly INSTALL_DIR=/opt/voicetranslator-autopilot
readonly SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)

if [[ ${EUID} -ne 0 ]]; then
  echo "Run this command as root." >&2
  exit 1
fi

install -d -o root -g root -m 0755 "${INSTALL_DIR}"
install -o root -g root -m 0755 "${SCRIPT_DIR}/autopilot.py" "${INSTALL_DIR}/autopilot.py"
install -o root -g root -m 0755 "${SCRIPT_DIR}/voicetranslator-autopilot-configure" \
  /usr/local/sbin/voicetranslator-autopilot-configure
install -o root -g root -m 0755 "${SCRIPT_DIR}/voicetranslator-autopilot-update" \
  /usr/local/sbin/voicetranslator-autopilot-update
install -o root -g root -m 0644 "${SCRIPT_DIR}/voicetranslator-autopilot.service" \
  /etc/systemd/system/voicetranslator-autopilot.service
install -o root -g root -m 0644 "${SCRIPT_DIR}/voicetranslator-autopilot.timer" \
  /etc/systemd/system/voicetranslator-autopilot.timer
install -o root -g root -m 0644 "${SCRIPT_DIR}/voicetranslator-autopilot-stop-all.service" \
  /etc/systemd/system/voicetranslator-autopilot-stop-all.service
install -d -o root -g root -m 0700 /var/lib/voicetranslator-autopilot
systemctl daemon-reload
echo "Installed VoiceTranslator autopilot files. The timer remains disabled until configuration."
