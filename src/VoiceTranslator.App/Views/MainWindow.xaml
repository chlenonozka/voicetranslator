<Window x:Class="VoiceTranslator.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:VoiceTranslator.App.Views"
        mc:Ignorable="d"
        Title="Voice Translator"
        Width="760"
        Height="720"
        MinWidth="620"
        MinHeight="620">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="28"
                           FontWeight="SemiBold"
                           Text="Russian voice translator" />
                <TextBlock Margin="0,6,0,0"
                           TextWrapping="Wrap"
                       Text="Translate Russian speech locally and play the translated voice through a physical output." />
            </StackPanel>

            <views:ModelSetupView Grid.Row="1"
                                  Margin="0,20,0,0" />

            <Grid Grid.Row="2"
                  Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.ColumnSpan="2">
                    <TextBlock FontWeight="SemiBold"
                               Text="Target language" />
                    <ComboBox Margin="0,6,0,0"
                              MinHeight="32"
                              AutomationProperties.Name="Target language"
                              DisplayMemberPath="DisplayName"
                              ItemsSource="{Binding TargetLanguages}"
                              SelectedItem="{Binding SelectedTargetLanguage}" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Margin="0,14,0,0">
                    <TextBlock FontWeight="SemiBold"
                               Text="Microphone" />
                    <ComboBox Margin="0,6,0,0"
                              MinHeight="32"
                              AutomationProperties.Name="Microphone"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding Microphones}"
                              SelectedItem="{Binding SelectedMicrophone}"
                              Text="No microphones available" />
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Margin="0,14,0,0">
                    <TextBlock FontWeight="SemiBold"
                               Text="Physical output" />
                    <ComboBox Margin="0,6,0,0"
                              MinHeight="32"
                              AutomationProperties.Name="Physical output device"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding PhysicalOutputs}"
                              SelectedItem="{Binding SelectedPhysicalOutput}"
                              Text="No physical outputs available" />
                </StackPanel>

                <StackPanel Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Margin="0,14,0,0">
                    <TextBlock FontWeight="SemiBold"
                               Text="Output mode" />
                    <ComboBox Margin="0,6,0,0"
                              MinHeight="32"
                              AutomationProperties.Name="Output mode"
                              ItemsSource="{Binding OutputModes}"
                              SelectedItem="{Binding SelectedOutputMode}" />
                </StackPanel>

                <StackPanel Grid.Row="4"
                            Grid.ColumnSpan="2"
                            Margin="0,14,0,0">
                    <TextBlock FontWeight="SemiBold"
                               Text="Virtual cable output" />
                    <ComboBox Margin="0,6,0,0"
                              MinHeight="32"
                              AutomationProperties.Name="Virtual cable output device"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding VirtualOutputs}"
                              SelectedItem="{Binding SelectedVirtualOutput}"
                              Text="No virtual outputs available" />
                    <TextBlock Margin="0,6,0,0"
                               AutomationProperties.Name="Output warning"
                               Text="{Binding OutputWarning}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <CheckBox Grid.Row="5"
                          Grid.ColumnSpan="2"
                          Margin="0,18,0,0"
                          Padding="0,4"
                          AutomationProperties.Name="Speaker timbre consent"
                          IsChecked="{Binding SpeakerConsentAccepted}">
                    <TextBlock TextWrapping="Wrap"
                               Text="I consent to using my speaker timbre for this session. The consent and speaker conditioning are not retained after the session." />
                </CheckBox>
            </Grid>

            <StackPanel Grid.Row="3"
                        Margin="0,22,0,0">
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,8,0">
                        <TextBlock FontWeight="SemiBold"
                                   Text="Microphone level" />
                        <ProgressBar Height="16"
                                     Margin="0,6,0,0"
                                     AutomationProperties.Name="Microphone level"
                                     Maximum="100"
                                     Value="{Binding InputLevelPercent, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="8,0,0,0">
                        <TextBlock FontWeight="SemiBold"
                                   Text="Output level" />
                        <ProgressBar Height="16"
                                     Margin="0,6,0,0"
                                     AutomationProperties.Name="Output level"
                                     Maximum="100"
                                     Value="{Binding OutputLevelPercent, Mode=OneWay}" />
                    </StackPanel>
                </Grid>

                <Border Padding="12"
                        Margin="0,0,0,12"
                        Background="#FFF8FBF0"
                        BorderBrush="#FFB7C98C"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock AutomationProperties.LiveSetting="Polite"
                               AutomationProperties.Name="Translation activity"
                               Text="{Binding ActivityMessage}"
                               TextWrapping="Wrap" />
                </Border>

                <Border Padding="12"
                        Background="#FFF3F6FA"
                        BorderBrush="#FF9AAFC4"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock x:Name="StatusTextBlock"
                               AutomationProperties.LiveSetting="Polite"
                               AutomationProperties.Name="Translation status"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />
                </Border>

                <StackPanel Margin="0,18,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <Button MinWidth="120"
                            MinHeight="38"
                            Margin="0,0,10,0"
                            AutomationProperties.Name="Start new session"
                            Command="{Binding NewSessionCommand}"
                            Content="_New session" />
                    <Button MinWidth="110"
                            MinHeight="38"
                            Margin="0,0,10,0"
                            AutomationProperties.Name="Start translation"
                            Command="{Binding StartCommand}"
                            Content="_Start"
                            IsDefault="True" />
                    <Button MinWidth="110"
                            MinHeight="38"
                            AutomationProperties.Name="Stop translation"
                            Command="{Binding StopCommand}"
                            Content="S_top"
                            IsCancel="True" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
