<Window x:Class="VoiceTranslator.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:VoiceTranslator.App.Views"
        xmlns:controls="clr-namespace:VoiceTranslator.App.Controls"
        xmlns:converters="clr-namespace:VoiceTranslator.App.Converters"
        mc:Ignorable="d"
        Title="Переводчик голоса"
        Width="760"
        Height="720"
        MinWidth="620"
        MinHeight="620">
    <Window.Resources>
        <converters:OutputModeDisplayConverter x:Key="OutputModeDisplayConverter" />
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="28"
                           FontWeight="SemiBold"
                           Text="Переводчик русской речи" />
                <TextBlock Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           Text="Локально переводит русскую речь и воспроизводит перевод выбранным голосом." />
            </StackPanel>

            <views:ModelSetupView Grid.Row="1"
                                  Margin="0,20,0,0" />

            <Grid Grid.Row="2"
                  Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.ColumnSpan="2">
                    <TextBlock FontWeight="SemiBold"
                               Text="Язык перевода" />
                    <ComboBox Margin="0,6,0,0"
                              MinHeight="32"
                              AutomationProperties.Name="Язык перевода"
                              DisplayMemberPath="DisplayName"
                              ItemsSource="{Binding TargetLanguages}"
                              SelectedItem="{Binding SelectedTargetLanguage}" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Margin="0,14,0,0">
                    <TextBlock FontWeight="SemiBold"
                               Text="Микрофон" />
                    <ComboBox Margin="0,6,0,0"
                              MinHeight="32"
                              AutomationProperties.Name="Микрофон"
                              DisplayMemberPath="Name"
                              IsEnabled="{Binding CanChangeConfiguration}"
                              ItemsSource="{Binding Microphones}"
                              SelectedItem="{Binding SelectedMicrophone}"
                              Text="Доступные микрофоны не найдены" />
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Margin="0,14,0,0">
                    <TextBlock FontWeight="SemiBold"
                               Text="Физический выход" />
                    <ComboBox Margin="0,6,0,0"
                              MinHeight="32"
                              AutomationProperties.Name="Устройство физического вывода"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding PhysicalOutputs}"
                              SelectedItem="{Binding SelectedPhysicalOutput}"
                              Text="Устройства вывода не найдены" />
                </StackPanel>

                <StackPanel Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Margin="0,14,0,0">
                    <TextBlock FontWeight="SemiBold"
                               Text="Режим вывода" />
                    <ComboBox Margin="0,6,0,0"
                              MinHeight="32"
                              AutomationProperties.Name="Режим вывода"
                              ItemsSource="{Binding OutputModes}"
                              SelectedItem="{Binding SelectedOutputMode}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource OutputModeDisplayConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="4"
                            Grid.ColumnSpan="2"
                            Margin="0,14,0,0">
                    <TextBlock FontWeight="SemiBold"
                               Text="Виртуальный выход для приложений" />
                    <ComboBox Margin="0,6,0,0"
                              MinHeight="32"
                              AutomationProperties.Name="Виртуальный выход для приложений"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding VirtualOutputs}"
                              SelectedItem="{Binding SelectedVirtualOutput}"
                              Text="Виртуальный аудиокабель не найден" />
                    <TextBlock Margin="0,6,0,0"
                               AutomationProperties.Name="Предупреждение о выводе"
                               Text="{Binding OutputWarning}"
                               TextWrapping="Wrap" />
                </StackPanel>

            </Grid>

            <StackPanel Grid.Row="3"
                        Margin="0,22,0,0">
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,8,0">
                        <TextBlock FontWeight="SemiBold"
                                   Text="Уровень микрофона" />
                        <ProgressBar Height="16"
                                     Margin="0,6,0,0"
                                     AutomationProperties.Name="Уровень микрофона"
                                     Maximum="100"
                                     Value="{Binding InputLevelPercent, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="8,0,0,0">
                        <TextBlock FontWeight="SemiBold"
                                   Text="Уровень вывода" />
                        <ProgressBar Height="16"
                                     Margin="0,6,0,0"
                                     AutomationProperties.Name="Уровень вывода"
                                     Maximum="100"
                                     Value="{Binding OutputLevelPercent, Mode=OneWay}" />
                    </StackPanel>
                </Grid>

                <Border Padding="12"
                        Margin="0,0,0,12"
                        Background="#FFF8FBF0"
                        BorderBrush="#FFB7C98C"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="76" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid Width="64"
                              Height="64"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center">
                            <controls:CircularProgressBar Value="{Binding TranslationProgressPercent}"
                                                          TrackBrush="#FFD8DED0"
                                                          ProgressBrush="#FF2E7D4F"
                                                          StrokeThickness="6" />
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="{Binding TranslationProgressPercent, StringFormat={}{0}%}" />
                        </Grid>
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       AutomationProperties.LiveSetting="Polite"
                                       AutomationProperties.Name="Этап перевода"
                                       Text="{Binding TranslationProgressLabel}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,4,0,0"
                                       AutomationProperties.LiveSetting="Polite"
                                       AutomationProperties.Name="Состояние перевода"
                                       Text="{Binding ActivityMessage}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Padding="12"
                        Background="#FFF3F6FA"
                        BorderBrush="#FF9AAFC4"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock x:Name="StatusTextBlock"
                               AutomationProperties.LiveSetting="Polite"
                               AutomationProperties.Name="Состояние сессии"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />
                </Border>

                <StackPanel Margin="0,14,0,0">
                    <TextBlock FontWeight="SemiBold"
                               Text="Голосовой профиль" />
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox MinHeight="32"
                                  AutomationProperties.Name="Голосовой профиль"
                                  DisplayMemberPath="Name"
                                  IsEnabled="{Binding CanChangeConfiguration}"
                                  ItemsSource="{Binding VoiceProfiles}"
                                  SelectedItem="{Binding SelectedVoiceProfile}"
                                  Text="Сохранённых профилей нет" />
                        <Button Grid.Column="1"
                                MinWidth="86"
                                MinHeight="32"
                                Margin="8,0,0,0"
                                AutomationProperties.Name="Создать голосовой профиль"
                                Command="{Binding NewVoiceProfileCommand}"
                                Content="Новый" />
                        <Button Grid.Column="2"
                                MinWidth="86"
                                MinHeight="32"
                                Margin="8,0,0,0"
                                AutomationProperties.Name="Удалить голосовой профиль"
                                Command="{Binding DeleteVoiceProfileCommand}"
                                Content="Удалить" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox MinHeight="32"
                                 Padding="8,5"
                                 AutomationProperties.Name="Имя голосового профиля"
                                 IsEnabled="{Binding CanChangeConfiguration}"
                                 MaxLength="60"
                                 Text="{Binding VoiceProfileName, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                MinWidth="120"
                                MinHeight="32"
                                Margin="8,0,0,0"
                                AutomationProperties.Name="Переименовать голосовой профиль"
                                Command="{Binding RenameVoiceProfileCommand}"
                                Content="Переименовать" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="#FF5B6570"
                                   AutomationProperties.LiveSetting="Polite"
                                   Text="{Binding VoiceProfileRecordingStatus}"
                                   TextWrapping="Wrap" />
                        <Button Grid.Column="1"
                                MinWidth="120"
                                MinHeight="32"
                                Margin="8,0,0,0"
                                AutomationProperties.Name="Начать запись голосового профиля"
                                Command="{Binding StartVoiceProfileRecordingCommand}"
                                Content="Начать запись" />
                        <Button Grid.Column="2"
                                MinWidth="110"
                                MinHeight="32"
                                Margin="8,0,0,0"
                                AutomationProperties.Name="Завершить запись голосового профиля"
                                Command="{Binding StopVoiceProfileRecordingCommand}"
                                Content="Завершить" />
                    </Grid>
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#FF5B6570"
                               TextWrapping="Wrap"
                               Text="Сохранённый профиль применяется автоматически ко всем языкам и новым сессиям." />
                </StackPanel>

                <StackPanel Margin="0,18,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <Button MinWidth="120"
                            MinHeight="38"
                            Margin="0,0,10,0"
                            AutomationProperties.Name="Новая сессия"
                            Command="{Binding NewSessionCommand}"
                            Content="_Новая сессия" />
                    <Button MinWidth="110"
                            MinHeight="38"
                            Margin="0,0,10,0"
                            AutomationProperties.Name="Запустить перевод"
                            Command="{Binding StartCommand}"
                            Content="_Запустить"
                            IsDefault="True" />
                    <Button MinWidth="110"
                            MinHeight="38"
                            AutomationProperties.Name="Остановить перевод"
                            Command="{Binding StopCommand}"
                            Content="_Остановить"
                            IsCancel="True" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
