<UserControl x:Class="VoiceTranslator.App.Views.ModelSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="Настройка моделей и сведения о лицензиях">
    <Border Padding="16"
            BorderBrush="#FFB8B8B8"
            BorderThickness="1"
            CornerRadius="4">
        <StackPanel>
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Text="Настройка моделей" />
            <TextBlock Margin="0,8,0,0"
                       AutomationProperties.Name="Состояние проверки моделей"
                       Text="{Binding ModelPreflightState}" />
            <TextBlock Margin="0,8,0,0"
                       FontWeight="SemiBold"
                       Text="Профиль производительности" />
            <ComboBox Margin="0,6,0,0"
                      MinHeight="32"
                      AutomationProperties.Name="Профиль производительности"
                      DisplayMemberPath="DisplayName"
                      IsEnabled="{Binding CanChangeConfiguration}"
                      ItemsSource="{Binding PerformanceProfiles}"
                      SelectedItem="{Binding SelectedPerformanceProfile}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#FF5B6570"
                       Text="{Binding PerformanceProfileDisplay, StringFormat=Рекомендованный при проверке: {0}}" />
            <TextBlock Margin="0,8,0,0"
                       AutomationProperties.Name="Сведения о моделях"
                       Text="{Binding ModelInventorySummary}"
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,12,0,0"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Text="NLLB и XTTS предназначены для личного некоммерческого использования. Перед загрузкой и использованием моделей ознакомьтесь с их лицензиями." />
        </StackPanel>
    </Border>
</UserControl>
